{
  // Name must match your Cloudflare Worker/project name.
  "name": "tech-blog",
  "compatibility_date": "2025-06-01",
  // Only serve on the custom domain — never on *.workers.dev.
  // Without these, every `wrangler deploy` re-enables the workers.dev route.
  "workers_dev": false,
  "preview_urls": false,
  // Serve the Hugo build output as static assets (no Worker script needed).
  "assets": {
    "directory": "./public"
  }
}
